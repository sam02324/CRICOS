# CRICOS environment — copy to ".env" and fill in from your Supabase project
# (Supabase dashboard → Project Settings → API). These are EXPO_PUBLIC_* so they
# are inlined into the app at build time. The anon key is safe to ship (Row Level
# Security protects the data).

EXPO_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key
